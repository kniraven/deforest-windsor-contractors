APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:GENERATE_A_KEY_AND_PASTE_IT_HERE
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=graph
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_USERNAME_HERE
MAIL_PASSWORD=YOUR_PASSWORD_HERE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=YOUR_EMAIL_HERE
MAIL_FROM_NAME="DeForest Connect/Network"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

DIRECTORY_ADMIN_EMAILS=YOUR_EMAIL_HERE
DIRECTORY_SUBMISSION_NOTIFICATION_EMAIL=YOUR_EMAIL_HERE

MICROSOFT_GRAPH_TENANT_ID=YOUR_TENANT_ID_HERE
MICROSOFT_GRAPH_CLIENT_ID=YOUR_CLIENT_ID_HERE
MICROSOFT_GRAPH_CLIENT_SECRET=YOUR_SECRET_HERE
MICROSOFT_GRAPH_SENDER_USER_ID=YOUR_SENDER_USER_ID_HERE
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
